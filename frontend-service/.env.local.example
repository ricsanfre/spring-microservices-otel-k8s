# Auth.js session encryption key — generate with: openssl rand -base64 32
AUTH_SECRET=

# Keycloak OIDC client (e-commerce-web — confidential BFF client)
AUTH_KEYCLOAK_ID=e-commerce-web
AUTH_KEYCLOAK_SECRET=<your-client-secret-here>
AUTH_KEYCLOAK_ISSUER=http://localhost:8180/realms/e-commerce

# Auth.js callback base URL (must match Keycloak redirectUri)
AUTH_URL=http://localhost:3001

# Microservice base URLs (local dev — in k8s use Kubernetes Service DNS)
PRODUCTS_SERVICE_URL=http://localhost:8081
ORDERS_SERVICE_URL=http://localhost:8082
REVIEWS_SERVICE_URL=http://localhost:8083
USERS_SERVICE_URL=http://localhost:8085
