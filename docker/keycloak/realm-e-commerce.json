{
  "realm": "e-commerce",
  "displayName": "E-Commerce Platform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "defaultSignatureAlgorithm": "RS256",

  "clientScopes": [
    {
      "name": "products:read",
      "description": "Read access to the product catalog",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "products:write",
      "description": "Create and update products (admin / product-service)",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "orders:read",
      "description": "Read access to orders",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "orders:write",
      "description": "Place and update orders",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "reviews:read",
      "description": "Read access to product reviews",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "reviews:write",
      "description": "Submit and edit reviews",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "users:read",
      "description": "Read own user profile",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    },
    {
      "name": "users:resolve",
      "description": "Resolve an IDP subject to an internal user ID (service-to-service only)",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "notifications:receive",
      "description": "Receive notification events",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "true" }
    }
  ],

  "clients": [
    {
      "clientId": "e-commerce-web",
      "name": "E-Commerce Web App",
      "description": "Public client — browser / SPA logins",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "webOrigins": ["+"],
      "defaultClientScopes": [
        "openid", "profile", "email",
        "products:read",
        "orders:read", "orders:write",
        "reviews:read", "reviews:write",
        "users:read"
      ],
      "optionalClientScopes": [
        "products:write"
      ]
    },
    {
      "clientId": "e-commerce-service",
      "name": "E-Commerce Service Client (M2M)",
      "description": "Confidential client for service-to-service client credentials flow",
      "enabled": true,
      "publicClient": false,
      "secret": "e-commerce-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "users:resolve"
      ],
      "optionalClientScopes": []
    }
  ],

  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "otheruser",
      "enabled": true,
      "email": "otheruser@example.com",
      "firstName": "Other",
      "lastName": "Person",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "service-account-e-commerce-service",
      "enabled": true,
      "email": "service-account-e-commerce-service@placeholder.org",
      "serviceAccountClientId": "e-commerce-service"
    }
  ]
}
